{
  "expo": {
    "name": "हिन्दी संस्कृत शब्दकोश",
    "slug": "shabdkosh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/shabd_logo.png",
    "scheme": "sabdkosh",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/shabd_logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fbf9f8",
        "foregroundImage": "./assets/images/shabd_logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jayeshkrishna.shabdkosh"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/shabd_logo.png",
          "imageWidth": 150
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
